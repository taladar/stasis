{
  "manifest_version": 2,
  "name": "Stasis Browser Activity",
  "version": "0.1.0",
  "description": "Reports real browser user activity to Stasis without using idle inhibitors.",
  "permissions": ["nativeMessaging", "<all_urls>", "tabs"],
  "background": {
    "scripts": ["src/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "stasis-browser-activity@saltnpepper97.github.io",
      "strict_min_version": "109.0"
    }
  }
}
